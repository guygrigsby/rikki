import "math"

fn main() {
    print(math.abs(-3))
    print(math.abs(-2.5))
    print(math.min(3, 7))
    print(math.max(3.0, 7.5))
    print(math.sqrt(16.0))
    print(math.pow(2.0, 10.0))
    print(math.floor(2.7))
    print(math.ceil(2.1))
    print(math.round(2.5))
    printf("%.5f\n", math.pi)
    printf("%.5f\n", math.e)
    printf("%.4f %.4f %.4f\n", math.cos(0.0), math.sin(math.pi / 2.0), math.tan(0.0))
    printf("%.4f\n", math.cos(math.pi))
    printf("%.4f\n", math.exp(1.0))
    printf("%.4f\n", math.ln(math.e))
    printf("%.4f\n", math.log(2.0, 1024.0))
    printf("%.4f\n", math.log(10.0, 1000.0))
}
