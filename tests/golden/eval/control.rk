fn main() {
    x := 7
    if x > 10 {
        print("big")
    } else if x > 5 {
        print("mid")
    } else {
        print("small")
    }
    for i := range 3 {
        print(i)
    }
    for _, i := range [2, 3, 4] {
        if i == 3 {
            continue
        }
        print(i)
    }
    n := 0
    for n < 3 {
        n = n + 1
    }
    print(n)
    for {
        print("once")
        break
    }
    for k, v := range map[str]int{"a": 1, "b": 2} {
        printf("%s=%d\n", k, v)
    }
}
