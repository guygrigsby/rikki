fn main() {
    s := "héllo"
    // two variables: code-point index and 1-char str, matching s[i]
    for i, c := range s {
        printf("%d:%s ", i, c)
    }
    printf("\n")
    // one variable: the index
    for i := range s {
        printf("%d", i)
    }
    printf("\n")
    // bare: once per character
    n := 0
    for range s {
        n = n + 1
    }
    print(n)
    // ord and chr
    print(charcode("A"))
    print(charcode("é"))
    print(char(65))
    print(char(233))
    print(char(charcode("Ω")))
    // build codepoints from a file-like string
    l := []int{}
    for _, c := range "hi" {
        l = append(l, charcode(c))
    }
    print(l)
}
