import "gpu"

fn main() (error?) {
    check gpu.lock("default", "holder")
    ok, err := gpu.trylock("default", "probe while held")
    if err != none {
        return err
    }
    print(ok)
    check gpu.unlock("default")
    ok2, err2 := gpu.trylock("default", "probe while free")
    if err2 != none {
        return err2
    }
    print(ok2)
    check gpu.unlock("default")
    return none
}
