// map repacks its result into the compact Value::Bytes exactly when the
// callback's declared return type is byte, on ANY receiver: the checker
// types those results []byte, so str/append/contains must see a compact
// buffer, not the boxed list list_method builds internally. The decision
// reads the declaration off the runtime fn value (FnRef::Decl -> fns
// table, FnRef::Closure -> ClosureData.ret); the checker guarantees a
// declaration always exists for byte-returning fns (a lambda inferring a
// byte return without declaring it is a compile error, see
// tests/golden/check/bytes-map-undeclared.nv).

fn identity(x byte) byte {
    return x
}

fn main() {
    b := []byte{104, 105}

    // declared-return lambda over []byte: the faulting repro, now green
    c := b.map(fn(x byte) byte { return x })
    s, _ := str(c)
    print(s)                        // hi
    d := append(c, 33)
    print(d.contains(byte(33)))     // true
    print(d.contains(105))          // true: bare literal needle still normalizes

    // declared top-level fn through FnRef::Decl
    e := b.map(identity)
    s2, _ := str(e)
    print(s2)                       // hi

    // plain []int receiver, byte-returning callback: the checker types
    // this []byte too, so it must come out compact just the same
    xs := [104, 105]
    f := xs.map(fn(x int) byte { return byte(x) })
    s3, _ := str(f)
    print(s3)                       // hi

    // empty receiver with a declared byte return repacks empty: append
    // must grow the compact buffer, not a boxed list
    g := []byte{}.map(fn(x byte) byte { return x })
    print(len(g))                   // 0
    h := append(g, 104)
    s4, _ := str(h)
    print(s4)                       // h
}
