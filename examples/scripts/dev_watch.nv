// dev-watch: build and run a binary, rebuild and bounce it when sources
// change. A port of the classic shell watcher; polls mtimes every two
// seconds, so it needs no fswatch or entr. Ctrl-C shuts down cleanly and
// promptly: the poll sleep is ctx-aware, and holding the process handle
// in-language replaces the shell version's PID files and lock file.
//
// Fully native: no import py anywhere. The proc module owns the child
// (its merged output pumps straight into the log), the poll sleep is
// ctx-aware, and the Proc handle replaces PID files and lock files.
//
// Conventions: a Makefile in the current dir exposing `make build` that
// produces ./<dirname>. Build output and the binary's output stream to
// the log; tail it in another pane.
//
// Knobs (env):
//   BIN        path to the built binary        (default ./<dirname>)
//   ARGS       extra launch args, space-separated
//   WATCH      dirs/files to watch, space-separated
//   WATCH_EXT  file suffixes to watch, space-separated
//   LOG        log path                        (default /tmp/<dirname>.log)
//
//   cd ~/code/foo && nv dev_watch.nv
//   ARGS="-addr :9000" nv dev_watch.nv
import "ctx"
import "file"
import "os"
import "proc"
import "time"

fn env(name str, fallback str) str {
    v := os.env(name)
    if v != none {
        return v
    }
    return fallback
}

fn two(n int) str {
    if n < 10 {
        return "0" + str(n)
    }
    return str(n)
}

fn stamp() str {
    p := time.parts(time.now())
    return two(p.hour) + ":" + two(p.minute) + ":" + two(p.second)
}


// One line to stdout and the log; a log write failure is reported, not fatal.
fn logline(log str, msg str) {
    line := sprintf("[%s] %s\n", stamp(), msg)
    printf("%s", line)
    aerr := file.append(log, line)
    if aerr != none {
        printf("log write failed: %s\n", aerr.msg)
    }
}


// Mtime fingerprint of everything watched; a changed, added, or removed
// file changes the string. Build output dirs are skipped so a build does
// not trigger the next build.
fn signature(root str, watch []str, exts []str) str {
    sig := ""
    for _, w := range watch {
        base := root + "/" + w
        if !file.exists(base) {
            continue
        }
        for _, ext := range exts {
            if base.has_suffix(ext) {
                m, merr := file.modified(base)
                if merr == none {
                    sig = sig + sprintf("%s %d\n", base, m)
                }
                continue
            }
            paths, gerr := file.glob(base + "/**/*" + ext)
            if gerr != none {
                continue
            }
            for _, p := range paths {
                if p.contains("/node_modules/") || p.contains("/dist/") || p.contains("/embedded/") || p.contains("/.git/") {
                    continue
                }
                m, merr := file.modified(p)
                if merr == none {
                    sig = sig + sprintf("%s %d\n", p, m)
                }
            }
        }
    }
    return sig
}

fn build(c Ctx, root str, log str) bool {
    logline(log, "build...")
    r, err := proc.exec(c, Cmd{
        argv: ["make", "build"],
        dir: root,
        env: map[str]str{},
        stdin: "",
        log: "",
    })
    if r.stdout + r.stderr != "" {
        aerr := file.append(log, r.stdout + r.stderr)
        if aerr != none {
            printf("log write failed: %s\n", aerr.msg)
        }
    }
    if err != none {
        logline(log, "BUILD FAILED: " + err.msg)
        return false
    }
    logline(log, "build ok")
    return true
}


// check propagates the spawn failure, so no zero Proc is ever needed
fn launch(root str, bin str, argv []str, log str) (Proc, error?) {
    cmd := []str{bin}
    for _, a := range argv {
        cmd = append(cmd, a)
    }
    p := check proc.start(Cmd{
        argv: cmd,
        dir: root,
        env: map[str]str{},
        stdin: "",
        log: log,
    })
    logline(log, sprintf("started pid %d", p.pid()))
    return p, none
}


// Terminate politely, escalate to kill if it lingers: proc.stop's
// whole contract, one call.
fn stop(p Proc, log str) {
    serr := p.stop(3 * time.second)
    if serr != none {
        logline(log, "stop failed: " + serr.msg)
    }
}

fn main() (error?) {
    root := check os.workdir()
    parts := root.split("/")
    name := parts[len(parts) - 1]
    bin := env("BIN", root + "/" + name)
    log := env("LOG", "/tmp/" + name + ".log")
    argv := []str{}
    argstr := env("ARGS", "")
    if argstr != "" {
        argv = argstr.split(" ")
    }
    watch := env("WATCH", "server web/src web/index.html cmd pkg internal main.go").split(" ")
    exts := env("WATCH_EXT", ".go .ts .svelte .css .html").split(" ")

    if !file.exists(root + "/Makefile") && !file.exists(root + "/makefile") {
        return error.new("no Makefile at " + root + "; dev-watch expects `make build` to work")
    }

    check file.write(log, "")
    logline(log, "dev-watch starting for " + name + "; logs at " + log)
    c := ctx.interrupt(ctx.background())
    if !build(c, root, log) {
        return error.new("initial build failed; see " + log)
    }
    if !file.exists(bin) {
        return error.new("no binary at " + bin + "; set BIN if make names it differently")
    }
    p := check launch(root, bin, argv, log)

    last := signature(root, watch, exts)
    logline(log, "watching (poll every 2s)")
    for !c.done() {
        serr := time.sleep(c, 2 * time.second)
        if serr != none {
            break  // interrupted mid-nap; shut down now, not in 2s
        }
        sig := signature(root, watch, exts)
        if sig == last {
            continue
        }
        derr := time.sleep(c, 400 * time.millisecond)  // debounce a multi-file save
        if derr != none {
            break
        }
        last = signature(root, watch, exts)
        logline(log, "change detected")
        stop(p, log)
        if !build(c, root, log) {
            logline(log, "nothing running until the next change builds")
            continue
        }
        if !file.exists(bin) {
            logline(log, "no binary at " + bin + "; set BIN if make names it differently")
            continue
        }
        np, serr2 := launch(root, bin, argv, log)
        if serr2 != none {
            logline(log, "start failed: " + serr2.msg)
            continue
        }
        p = np
    }

    logline(log, "interrupted; shutting down")
    stop(p, log)
    return none
}
